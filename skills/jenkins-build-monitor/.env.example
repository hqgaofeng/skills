# === jenkins-build-monitor v1.2.0 必需配置 ===
# 复制本文件内容到 ~/.hermes/.env, 填入真实值

# ===== Jenkins =====
JENKINS_URL=http://jenkins.your-company.com:8080
JENKINS_USER=jenkins
JENKINS_PASS=your_jenkins_password

# ===== 编译服务器 (SSH) =====
BUILD_SERVER_USER=builder
BUILD_SERVER_PASS=your_build_server_password
# 备用密码 (可选)
BUILD_SERVER_PASS_ALT=your_alt_password

# 你的 SSH 公钥 (新服务器自动部署用)
# 生成: ssh-keygen -t rsa; cat ~/.ssh/id_rsa.pub
MY_SSH_PUB_KEY="ssh-rsa AAAAB3NzaC1yc2EAAAA... user@host"

# ===== 飞书 (可选, 不配 = 跳过飞书通知和写表) =====
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=***_SHEETS_TOKEN_BUILD=***  # 构建记录表的 token
FEISHU_SHEET_ID_BUILD=***  # 构建记录表的 ID (从 sheets/query 查, 不是 "Sheet1" 或 "0")

FEISHU_CHAT_ID=oc_xxxxxxxxxxxx  # 飞书 chat_id (send_message 目标)

# ===== 企业微信 (可选) =====
# 通用 URL (所有项目都发)
WX_WORK_WEBHOOK_URL_GENERAL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_GENERAL_KEY

# 项目专用 (可选, 按 project 字段匹配)
# 变量名规则: WX_WORK_WEBHOOK_URL_<UPPER_PROJECT_WITH_UNDERSCORE>
# 例: project = "sm68b-do" → 变量名 = "WX_WORK_WEBHOOK_URL_SM68B_DO"
WX_WORK_WEBHOOK_URL_SM68B_DO=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_SM68B_KEY

# ===== 通用配置 =====
# 本地时区偏移 (小时), 默认 8 (北京)
LOCAL_TZ_OFFSET_HOURS=8

# 自定义噪音正则 (可选, 跨项目通用)
# 默认已含 SM68B 等模式, 部署到其他项目时, 这里覆盖:
# 多个模式用 | 分隔
JOB_NAME_PATTERN=^\[MYPROJECT_\w+_trigger\]

# Git root 推断规则 (可选, 跨项目通用)
# 格式: <路径前缀>=<git_subdir>; (多选用 ; 分隔)
# 例: Android QCOM 多仓库
WORKSPACE_GIT_RULES=boot_images=boot_images;vendor/qcom=vendor/qcom;kernel=kernel;

# ===== analyze_history.py 用 (可选) =====
# 逗号分隔多个 job 名
TARGET_JOBS=myapp-prod,myapp-staging
# 分析窗口 (最近 N 个 build), 默认 100
ANALYZE_WINDOW_SIZE=100
