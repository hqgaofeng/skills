# === jenkins-user-sync-monitor v1.1.0 必需配置 ===
# 复制本文件内容到 ~/.hermes/.env, 填入真实值

# ===== Jenkins =====
JENKINS_URL=http://jenkins.your-company.com:8080
JENKINS_USER=jenkins
JENKINS_PASS=your_jenkins_password

# ===== 业务配置 (必填) =====
# 目标公司: 你的公司全名 (跟 console 里的 USER INFO 行公司名完全一致)
TARGET_COMPANY=Your Company Ltd

# 失败关键词 (逗号分隔, 默认常见用户同步失败)
# 默认已够用, 你的公司有特殊关键词可追加
FAILURE_KEYWORDS=创建用户失败,单用户方式创建失败,invalid phone number for

# 时区偏移 (小时), 默认 8 (北京)
LOCAL_TZ_OFFSET_HOURS=8

# ===== 飞书 (可选, 不配 = 跳过飞书通知和写表) =====
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=*** _SH...=***  # 同步记录表的 token (跟构建记录表分开)
FEISHU_SHEET_ID_SYNC=***  # 同步记录表的 ID

FEISHU_CHAT_ID=oc_xxxxxxxxxxxx  # 飞书 chat_id (send_message 目标)
